{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to the user's profile picture." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role in the system." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A jewelry item available for sale.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer's purchase record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "A product saved to a user's wishlist.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "emailVerificationEnabled": { "type": "boolean" },
        "phoneVerificationEnabled": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Subscriber": {
      "title": "Newsletter Subscriber",
      "description": "A user who subscribed to the newsletter.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "subscribedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "subscribedAt"]
    },
    "Reel": {
      "title": "Instagram Reel",
      "description": "A short video linked to a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "videoUrl": { "type": "string", "format": "uri" },
        "embedCode": { "type": "string" },
        "productId": { "type": "string" },
        "caption": { "type": "string" },
        "thumbnail": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId"]
    },
    "Collection": {
      "title": "Product Collection",
      "description": "A group of products.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "productIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "productIds"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "Article for the store blog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string", "format": "uri" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "content", "author"]
    },
    "Page": {
      "title": "Static Page",
      "description": "Static content page like About Us or FAQ.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "content": { "type": "string" },
        "isVisible": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content"]
    },
    "ThemeConfig": {
      "title": "Store Theme Configuration",
      "description": "Global styles and configuration for the store frontend.",
      "type": "object",
      "properties": {
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "announcements": { "type": "array", "items": { "type": "string" } },
        "showAnnouncementBar": { "type": "boolean" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "fontFamily": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/collections/{collectionId}": {
      "schema": "Collection",
      "description": "Custom product collections."
    },
    "/blog/{postId}": {
      "schema": "BlogPost",
      "description": "Store blog articles."
    },
    "/pages/{pageId}": {
      "schema": "Page",
      "description": "Static store pages."
    },
    "/settings/theme_config": {
      "schema": "ThemeConfig",
      "description": "Global store appearance settings."
    },
    "/reels/{reelId}": {
      "schema": "Reel",
      "description": "Video reels for products."
    },
    "/subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Newsletter subscriptions."
    },
    "/settings/{settingId}": {
      "schema": "AppSettings",
      "description": "Global application settings."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/users/{userId}/wishlist/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "User-specific wishlist items."
    }
  }
}
