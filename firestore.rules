rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      // Just check email for now to bypass complex logic during debug
      let isAuth = request.auth != null;
      let hasEmail = isAuth && 'email' in request.auth.token;
      return hasEmail && (request.auth.token.email == "business.saloarhussain@gmail.com" || request.auth.token.email == "minecom2024@gmail.com");
    }

    match /users/{userId} {
      allow read, write: if true;
    }
    match /products/{productId} {
      allow read, write: if true;
    }
    match /orders/{orderId} {
      allow read, write: if true;
    }
    match /settings/{settingId} {
      allow read, write: if true;
    }
    match /reels/{reelId} {
      allow read, write: if true;
    }
    match /collections/{collectionId} {
      allow read, write: if true;
    }
    match /blog/{postId} {
      allow read, write: if true;
    }
    match /pages/{pageId} {
      allow read, write: if true;
    }
    match /subscribers/{subscriberId} {
      allow read, write: if true;
    }
    
    // Everything else
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
